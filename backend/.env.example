# =============================================================================
# Backend H3-CoqueGuide — variables de entorno
# =============================================================================
# Copia este archivo a `.env` y rellena con valores reales.
# `.env` está en `.gitignore` — NUNCA lo commitees.
#
#   cp .env.example .env
#
# Las credenciales reales de la BD las da el socio formador.
# =============================================================================

# --- Conexión a Postgres (GCP Cloud SQL) ---
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=postgres

# Forzar conexión cifrada (Cloud SQL la exige).
PGSSLMODE=require

# --- Servidor HTTP ---
# Puerto en el que corre el servidor local.
# En Vercel NO se usa: la plataforma envuelve el `app` como serverless function.
PORT=8080

# --- Gemini (Google Generative Language API) ---
# La API key vive ÚNICAMENTE en el server (antes estaba embebida en el binario
# de iOS, lo cual era inseguro). Pídela en Google AI Studio:
#   https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Modelo a usar. Si lo dejas vacío, el cliente usa `gemini-2.5-flash` por default.
GEMINI_MODEL=
