# =============================================================================
# Backend H3-CoqueGuide — variables de entorno
# =============================================================================
# Copia este archivo a `.env` y rellena con valores reales.
# `.env` está en `.gitignore` — NUNCA lo commitees.
#
#   cp .env.example .env
#
# Las credenciales reales de la BD las da el socio formador.
# =============================================================================

# --- Conexión a Postgres (GCP Cloud SQL) ---
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=postgres

# Forzar conexión cifrada (Cloud SQL la exige).
PGSSLMODE=require

# --- Servidor HTTP ---
# Puerto en el que corre el servidor local.
# Cloud Run inyecta su propio PORT cuando deploya, así que dejarlo configurable.
PORT=8080
